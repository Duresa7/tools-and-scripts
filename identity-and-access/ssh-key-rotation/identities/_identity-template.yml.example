---
# Copy this file to identities/<identity-id>.yml. Only public-key data belongs here.
ssh_identity:
  # CUSTOMIZE: Match the lowercase identity filename without .yml.
  id: workstation-key
  # CUSTOMIZE: Name the person or device that owns this public key.
  display_name: Workstation key
  # CUSTOMIZE: Run `ssh-keygen -lf <public-key-file>` and copy its SHA256 value.
  fingerprint: SHA256:REPLACE_WITH_PUBLIC_KEY_FINGERPRINT
  # CUSTOMIZE: Paste one complete public-key line. Never paste a private key.
  current_public_key: ssh-ed25519 REPLACE_WITH_PUBLIC_KEY_DATA workstation-key
  # CUSTOMIZE: List exact aliases from inventory/hosts.yml.
  target_hosts:
    - posix-standard-example
  rotation:
    # CUSTOMIZE: Leave empty until a distinct replacement public key is ready.
    replacement_public_key: ''
    # CUSTOMIZE: Set true only after replacement login succeeds on every target.
    operator_verified: false

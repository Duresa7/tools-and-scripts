---
# CUSTOMIZE: Copy this file to hosts.yml, then replace every *-example alias,
# documentation IP address, login user, and authorized_keys path. Identity
# target_hosts values must refer to the aliases defined here, not IP addresses.
all:
  children:
    ssh_key_supported:
      children:
        posix_ssh_key_hosts:
          vars:
            ssh_key_platform: posix
            ssh_key_write_enabled: true
          hosts:
            # CUSTOMIZE: Rename the alias and set the address, SSH user, and key
            # file used by that account. Add more hosts at this indentation.
            linux-example:
              ansible_host: 192.0.2.10
              ansible_user: admin
              ssh_authorized_keys_path: /home/admin/.ssh/authorized_keys

        # CUSTOMIZE: Use this group only when several hosts read one shared key
        # file. Exactly one inventory host should be allowed to write that file.
        shared_posix_key_hosts:
          vars:
            ssh_key_platform: posix
            ssh_authorized_keys_path: /srv/cluster/authorized_keys
          hosts:
            # CUSTOMIZE: This host performs the one write to the shared key file.
            cluster-writer-example:
              ansible_host: 192.0.2.20
              ansible_user: root
              ssh_key_write_enabled: true
            # CUSTOMIZE: Readers verify the shared file but do not change it.
            # Point ssh_key_shared_writer at the writer alias above.
            cluster-reader-example:
              ansible_host: 192.0.2.21
              ansible_user: root
              ssh_key_write_enabled: false
              ssh_key_shared_writer: cluster-writer-example

        windows_ssh_key_hosts:
          vars:
            ansible_connection: ssh
            ansible_shell_type: powershell
            ssh_key_platform: windows
            ssh_key_write_enabled: true
          hosts:
            # CUSTOMIZE: Set the Windows host, OpenSSH account, and authorized
            # keys file. Administrators commonly use the path shown below.
            windows-example:
              ansible_host: 192.0.2.30
              ansible_user: Administrator
              ssh_authorized_keys_path: 'C:\ProgramData\ssh\administrators_authorized_keys'

    # CUSTOMIZE: Keep unverified hosts here until you have confirmed their key
    # path and platform. The operational playbooks cannot target this group.
    ssh_key_unknown:
      hosts:
        unverified-example:
          ansible_host: 192.0.2.40

    # Managed at runtime by the playbooks. Do not add hosts to this group.
    ssh_identity_runtime_targets:
      hosts: {}
